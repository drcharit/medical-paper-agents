{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medical-paper-agents/results-package-schema.json",
  "title": "Results Package Schema",
  "description": "JSON Schema for results_package.json -- the single source of truth for all numbers in the manuscript. Every writing agent reads from this file. No writing agent ever computes a number.",
  "type": "object",
  "required": [
    "metadata",
    "populations",
    "primary_outcome",
    "secondary_outcomes",
    "subgroup_analyses",
    "sensitivity_analyses",
    "table1_data",
    "consort_flow",
    "survival_data",
    "missing_data"
  ],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Study metadata and provenance information",
      "required": [
        "study_name",
        "study_type",
        "journal_target",
        "date_generated",
        "data_hash",
        "software_versions",
        "agent",
        "sap_version",
        "package_hash"
      ],
      "additionalProperties": false,
      "properties": {
        "study_name": {
          "type": "string",
          "description": "Human-readable study name or identifier"
        },
        "study_type": {
          "type": "string",
          "enum": [
            "rct",
            "cohort",
            "case_control",
            "cross_sectional",
            "systematic_review",
            "meta_analysis",
            "case_report",
            "case_series",
            "diagnostic_accuracy",
            "health_economic"
          ],
          "description": "Study design type"
        },
        "journal_target": {
          "type": "string",
          "description": "Target journal for submission (e.g., lancet, nejm, jama, bmj, circulation)"
        },
        "date_generated": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of package generation"
        },
        "data_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of the primary analysis dataset used"
        },
        "software_versions": {
          "type": "object",
          "description": "Versions of all software used in analysis",
          "required": ["python"],
          "properties": {
            "python": { "type": "string" },
            "pandas": { "type": "string" },
            "polars": { "type": "string" },
            "numpy": { "type": "string" },
            "scipy": { "type": "string" },
            "statsmodels": { "type": "string" },
            "lifelines": { "type": "string" },
            "scikit_survival": { "type": "string" },
            "scikit_learn": { "type": "string" },
            "miceforest": { "type": "string" }
          },
          "additionalProperties": true
        },
        "agent": {
          "type": "string",
          "const": "Agent 18 (Data Analyst)",
          "description": "Producing agent identifier"
        },
        "sap_version": {
          "type": "string",
          "description": "Version or hash of the SAP used"
        },
        "package_hash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$",
          "description": "SHA-256 hash of this results package (computed over all other fields)"
        }
      }
    },

    "populations": {
      "type": "object",
      "description": "Analysis population definitions with counts",
      "required": ["primary_population"],
      "properties": {
        "primary_population": {
          "type": "string",
          "enum": ["itt", "mitt", "pp", "safety", "full_cohort", "matched_cohort"],
          "description": "Which population was used for the primary analysis"
        },
        "itt": { "$ref": "#/$defs/population_definition" },
        "mitt": { "$ref": "#/$defs/population_definition" },
        "pp": { "$ref": "#/$defs/population_definition" },
        "safety": { "$ref": "#/$defs/population_definition" },
        "full_cohort": { "$ref": "#/$defs/population_definition" },
        "matched_cohort": { "$ref": "#/$defs/population_definition" },
        "complete_case": { "$ref": "#/$defs/population_definition" }
      },
      "additionalProperties": false
    },

    "primary_outcome": {
      "$ref": "#/$defs/outcome_result",
      "description": "Primary endpoint analysis result"
    },

    "secondary_outcomes": {
      "type": "array",
      "description": "All secondary endpoint analysis results",
      "items": { "$ref": "#/$defs/outcome_result" }
    },

    "subgroup_analyses": {
      "type": "array",
      "description": "All pre-specified subgroup analyses",
      "items": { "$ref": "#/$defs/subgroup_analysis" }
    },

    "sensitivity_analyses": {
      "type": "array",
      "description": "All sensitivity and robustness analyses",
      "items": { "$ref": "#/$defs/sensitivity_analysis" }
    },

    "table1_data": {
      "type": "object",
      "description": "Structured baseline characteristics data",
      "required": ["mode", "arms", "total_n", "variables"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["rct", "observational"],
          "description": "RCT mode omits p-values; observational includes them"
        },
        "arms": {
          "type": "array",
          "description": "Treatment arm labels in order",
          "items": { "type": "string" },
          "minItems": 2
        },
        "total_n": {
          "type": "integer",
          "minimum": 1,
          "description": "Total N in Table 1"
        },
        "n_per_arm": {
          "type": "object",
          "description": "N per arm, keyed by arm label",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "variables": {
          "type": "array",
          "description": "Baseline characteristics in presentation order",
          "items": { "$ref": "#/$defs/table1_variable" }
        },
        "footnotes": {
          "type": "array",
          "description": "Table footnotes",
          "items": { "type": "string" }
        }
      }
    },

    "consort_flow": {
      "type": "object",
      "description": "CONSORT or STROBE participant flow data",
      "required": ["flow_type"],
      "additionalProperties": false,
      "properties": {
        "flow_type": {
          "type": "string",
          "enum": ["consort", "strobe"],
          "description": "Flow diagram type based on study design"
        },
        "assessed": {
          "type": "integer",
          "minimum": 0,
          "description": "N assessed for eligibility"
        },
        "excluded": {
          "type": "object",
          "required": ["n_total", "reasons"],
          "additionalProperties": false,
          "properties": {
            "n_total": {
              "type": "integer",
              "minimum": 0
            },
            "reasons": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["reason", "n"],
                "additionalProperties": false,
                "properties": {
                  "reason": { "type": "string" },
                  "n": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        },
        "randomised": {
          "type": "integer",
          "minimum": 0,
          "description": "N randomised (RCT) or enrolled (observational)"
        },
        "allocated": {
          "type": "object",
          "description": "Allocation per arm (keyed by arm label)",
          "additionalProperties": { "$ref": "#/$defs/allocation_arm" }
        },
        "followup": {
          "type": "object",
          "description": "Follow-up attrition per arm (keyed by arm label)",
          "additionalProperties": { "$ref": "#/$defs/followup_arm" }
        },
        "analysed": {
          "type": "object",
          "description": "Analysed per arm per population (keyed by arm label)",
          "additionalProperties": { "$ref": "#/$defs/analysed_arm" }
        }
      }
    },

    "survival_data": {
      "type": "object",
      "description": "Survival analysis outputs (KM, log-rank, follow-up)",
      "required": ["median_followup_months", "median_followup_method"],
      "additionalProperties": false,
      "properties": {
        "median_followup_months": {
          "type": "number",
          "minimum": 0,
          "description": "Median follow-up duration in months"
        },
        "median_followup_method": {
          "type": "string",
          "enum": ["reverse_kaplan_meier", "standard_median", "simple_median"],
          "description": "Method used to compute median follow-up"
        },
        "iqr_followup_months": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2,
          "description": "[Q1, Q3] of follow-up in months"
        },
        "mean_followup_months": {
          "type": "number",
          "minimum": 0
        },
        "total_person_years": {
          "type": "number",
          "minimum": 0,
          "description": "Total person-years of follow-up"
        },
        "log_rank_p": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Log-rank test p-value for primary endpoint"
        },
        "km_estimates": {
          "type": "object",
          "description": "KM survival estimates per arm, keyed by arm label",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/km_timepoint" }
          }
        },
        "number_at_risk": {
          "type": "object",
          "description": "Number at risk per arm at each time point, keyed by arm label",
          "additionalProperties": {
            "type": "array",
            "items": { "$ref": "#/$defs/risk_timepoint" }
          }
        },
        "median_survival": {
          "type": "object",
          "description": "Median survival time per arm (if estimable), keyed by arm label",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "median_months": { "type": ["number", "null"] },
              "ci_lower": { "type": ["number", "null"] },
              "ci_upper": { "type": ["number", "null"] }
            }
          }
        }
      }
    },

    "missing_data": {
      "type": "object",
      "description": "Missing data assessment and handling summary",
      "required": ["mechanism_assumption", "method"],
      "additionalProperties": false,
      "properties": {
        "mechanism_assumption": {
          "type": "string",
          "enum": ["MCAR", "MAR", "MNAR", "complete_data"],
          "description": "Assumed missing data mechanism"
        },
        "evidence_for_assumption": {
          "type": "string",
          "description": "Statistical and clinical evidence supporting the mechanism assumption"
        },
        "method": {
          "type": "string",
          "enum": [
            "complete_case",
            "single_imputation_mean",
            "single_imputation_median",
            "single_imputation_mode",
            "multiple_imputation_mice",
            "multiple_imputation_pmm",
            "multiple_imputation_rf",
            "maximum_likelihood",
            "inverse_probability_weighting",
            "pattern_mixture_model",
            "none_complete_data"
          ],
          "description": "Method used to handle missing data"
        },
        "n_imputations": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Number of imputed datasets (null if not applicable)"
        },
        "iterations_per_imputation": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "MICE iterations per imputed dataset"
        },
        "variables_imputed": {
          "type": "array",
          "description": "List of variables that were imputed",
          "items": { "type": "string" }
        },
        "n_subjects_with_imputed_values": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Number of subjects with at least one imputed value"
        },
        "pooling_method": {
          "type": ["string", "null"],
          "enum": ["rubins_rules", "li_raghunathan_rubin", null],
          "description": "Method for pooling imputed estimates"
        },
        "littles_mcar_test": {
          "type": ["object", "null"],
          "description": "Results of Little's MCAR test",
          "properties": {
            "chi2": { "type": "number" },
            "df": { "type": "integer" },
            "p_value": { "type": "number" }
          }
        },
        "variables_predictive_of_missingness": {
          "type": "array",
          "description": "Variables that predict missingness (from logistic regression)",
          "items": { "type": "string" }
        },
        "missingness_pattern": {
          "type": ["string", "null"],
          "enum": ["monotone", "non_monotone", "arbitrary", null],
          "description": "Pattern of missingness across variables"
        },
        "per_variable_summary": {
          "type": "array",
          "description": "Missingness summary per variable",
          "items": {
            "type": "object",
            "required": ["variable", "n_missing", "pct_missing"],
            "additionalProperties": false,
            "properties": {
              "variable": { "type": "string" },
              "n_missing": { "type": "integer", "minimum": 0 },
              "pct_missing": { "type": "number", "minimum": 0, "maximum": 100 },
              "n_missing_per_arm": {
                "type": "object",
                "additionalProperties": { "type": "integer", "minimum": 0 }
              },
              "likely_mechanism": {
                "type": "string",
                "enum": ["MCAR", "MAR", "MNAR", "unknown"]
              }
            }
          }
        }
      }
    }
  },

  "$defs": {
    "population_definition": {
      "type": "object",
      "description": "Definition and counts for an analysis population",
      "required": ["n_total"],
      "additionalProperties": false,
      "properties": {
        "n_total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total N in this population"
        },
        "n_per_arm": {
          "type": "object",
          "description": "N per arm, keyed by arm label",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "events": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total primary endpoint events in this population"
        },
        "events_per_arm": {
          "type": ["object", "null"],
          "description": "Events per arm, keyed by arm label",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "person_years": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Total person-years of follow-up in this population"
        },
        "person_years_per_arm": {
          "type": ["object", "null"],
          "description": "Person-years per arm, keyed by arm label",
          "additionalProperties": { "type": "number", "minimum": 0 }
        },
        "definition": {
          "type": "string",
          "description": "Plain-language definition of this population"
        },
        "exclusion_reasons": {
          "type": "array",
          "description": "Reasons for exclusion from this population (relative to ITT)",
          "items": {
            "type": "object",
            "required": ["reason", "n"],
            "properties": {
              "reason": { "type": "string" },
              "n": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },

    "outcome_result": {
      "type": "object",
      "description": "Statistical result for a single outcome analysis",
      "required": [
        "analysis_name",
        "endpoint",
        "population",
        "model",
        "effect_measure",
        "estimate",
        "ci_lower",
        "ci_upper",
        "p_value",
        "n_treatment",
        "n_control",
        "events_treatment",
        "events_control"
      ],
      "additionalProperties": false,
      "properties": {
        "analysis_name": {
          "type": "string",
          "description": "Unique identifier for this analysis (e.g., primary, secondary_cv_death)"
        },
        "endpoint": {
          "type": "string",
          "description": "Name of the endpoint analysed"
        },
        "endpoint_type": {
          "type": "string",
          "enum": ["time_to_event", "binary", "continuous", "count", "ordinal"],
          "description": "Type of endpoint"
        },
        "population": {
          "type": "string",
          "description": "Analysis population used (itt, mitt, pp, safety, etc.)"
        },
        "model": {
          "type": "string",
          "enum": [
            "cox_ph",
            "logistic_regression",
            "linear_regression",
            "mixed_model",
            "poisson_regression",
            "negative_binomial",
            "fine_gray",
            "log_binomial",
            "ordinal_logistic",
            "kaplan_meier",
            "other"
          ],
          "description": "Statistical model used"
        },
        "effect_measure": {
          "type": "string",
          "enum": ["HR", "OR", "RR", "RD", "MD", "SMD", "IRR", "NNT", "AUC", "other"],
          "description": "Effect measure reported"
        },
        "estimate": {
          "type": "number",
          "description": "Point estimate of the effect"
        },
        "ci_lower": {
          "type": "number",
          "description": "Lower bound of 95% confidence interval"
        },
        "ci_upper": {
          "type": "number",
          "description": "Upper bound of 95% confidence interval"
        },
        "ci_level": {
          "type": "number",
          "default": 0.95,
          "description": "Confidence level (default 0.95 for 95% CI)"
        },
        "p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "P-value for the effect estimate"
        },
        "n_treatment": {
          "type": "integer",
          "minimum": 0,
          "description": "N in treatment/exposed group"
        },
        "n_control": {
          "type": "integer",
          "minimum": 0,
          "description": "N in control/unexposed group"
        },
        "events_treatment": {
          "type": "integer",
          "minimum": 0,
          "description": "Events in treatment/exposed group"
        },
        "events_control": {
          "type": "integer",
          "minimum": 0,
          "description": "Events in control/unexposed group"
        },
        "rate_treatment": {
          "type": ["number", "null"],
          "description": "Event rate in treatment group (per 100 person-years or percentage)"
        },
        "rate_control": {
          "type": ["number", "null"],
          "description": "Event rate in control group"
        },
        "rate_unit": {
          "type": ["string", "null"],
          "enum": ["percent", "per_100_person_years", "per_1000_person_years", null],
          "description": "Unit for event rates"
        },
        "person_years_treatment": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Person-years in treatment group"
        },
        "person_years_control": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Person-years in control group"
        },
        "covariates_adjusted": {
          "type": "array",
          "description": "List of covariates in the adjusted model",
          "items": { "type": "string" }
        },
        "multiplicity_adjustment": {
          "type": ["string", "null"],
          "description": "Multiplicity adjustment method (e.g., bonferroni, holm, hierarchical)"
        },
        "adjusted_p_value": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1,
          "description": "P-value after multiplicity adjustment"
        },
        "model_details": {
          "type": "object",
          "description": "Additional model-specific diagnostics",
          "properties": {
            "concordance": { "type": "number" },
            "auc": { "type": "number" },
            "r_squared": { "type": "number" },
            "adjusted_r_squared": { "type": "number" },
            "log_likelihood": { "type": "number" },
            "aic": { "type": "number" },
            "bic": { "type": "number" },
            "n_observations": { "type": "integer" },
            "n_events": { "type": "integer" },
            "degrees_of_freedom": { "type": "integer" }
          },
          "additionalProperties": true
        }
      }
    },

    "subgroup_analysis": {
      "type": "object",
      "description": "Subgroup analysis with interaction test",
      "required": ["subgroup_name", "endpoint", "interaction_p", "levels"],
      "additionalProperties": false,
      "properties": {
        "subgroup_name": {
          "type": "string",
          "description": "Name of the subgroup variable (e.g., age_group, sex, diabetes)"
        },
        "endpoint": {
          "type": "string",
          "description": "Endpoint analysed in this subgroup analysis"
        },
        "interaction_p": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "P-value for treatment x subgroup interaction"
        },
        "interaction_method": {
          "type": "string",
          "description": "Method for interaction test (e.g., likelihood_ratio, wald)"
        },
        "pre_specified": {
          "type": "boolean",
          "description": "Whether this subgroup was pre-specified in the SAP"
        },
        "levels": {
          "type": "array",
          "description": "Effect estimates per subgroup level",
          "items": {
            "type": "object",
            "required": [
              "level",
              "n_treatment",
              "n_control",
              "events_treatment",
              "events_control",
              "effect_measure",
              "estimate",
              "ci_lower",
              "ci_upper"
            ],
            "additionalProperties": false,
            "properties": {
              "level": {
                "type": "string",
                "description": "Subgroup level label (e.g., '<65', '>=65')"
              },
              "n_treatment": { "type": "integer", "minimum": 0 },
              "n_control": { "type": "integer", "minimum": 0 },
              "events_treatment": { "type": "integer", "minimum": 0 },
              "events_control": { "type": "integer", "minimum": 0 },
              "effect_measure": {
                "type": "string",
                "enum": ["HR", "OR", "RR", "RD", "MD", "SMD", "IRR", "other"]
              },
              "estimate": { "type": "number" },
              "ci_lower": { "type": "number" },
              "ci_upper": { "type": "number" },
              "p_value": {
                "type": ["number", "null"],
                "minimum": 0,
                "maximum": 1
              }
            }
          }
        }
      }
    },

    "sensitivity_analysis": {
      "type": "object",
      "description": "Sensitivity or robustness analysis result",
      "required": [
        "analysis_name",
        "description",
        "effect_measure",
        "estimate",
        "ci_lower",
        "ci_upper",
        "p_value"
      ],
      "additionalProperties": false,
      "properties": {
        "analysis_name": {
          "type": "string",
          "description": "Unique identifier (e.g., per_protocol, complete_case, unadjusted)"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the sensitivity analysis"
        },
        "population": {
          "type": "string",
          "description": "Population used for this analysis"
        },
        "model": {
          "type": "string",
          "description": "Statistical model used"
        },
        "effect_measure": {
          "type": "string",
          "enum": ["HR", "OR", "RR", "RD", "MD", "SMD", "IRR", "other"]
        },
        "estimate": { "type": "number" },
        "ci_lower": { "type": "number" },
        "ci_upper": { "type": "number" },
        "p_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "n_analysed": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "N in this sensitivity analysis"
        },
        "n_events": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "Total events in this sensitivity analysis"
        },
        "comparison_to_primary": {
          "type": "string",
          "description": "Brief comparison of this result to the primary analysis"
        },
        "conclusion": {
          "type": "string",
          "enum": ["consistent", "attenuated", "strengthened", "reversed", "inconclusive"],
          "description": "Direction of sensitivity analysis relative to primary"
        }
      }
    },

    "table1_variable": {
      "type": "object",
      "description": "A single variable row in Table 1",
      "required": ["variable_name", "display_name", "variable_type"],
      "additionalProperties": false,
      "properties": {
        "variable_name": {
          "type": "string",
          "description": "Internal variable name"
        },
        "display_name": {
          "type": "string",
          "description": "Display label for Table 1 (e.g., 'Age, years -- mean (SD)')"
        },
        "category": {
          "type": "string",
          "description": "Section header (e.g., 'Demographics', 'Medical history', 'Medications')"
        },
        "variable_type": {
          "type": "string",
          "enum": ["continuous_normal", "continuous_skewed", "categorical", "binary"],
          "description": "Determines summary format: mean(SD), median(IQR), n(%), or n(%)"
        },
        "summary_per_arm": {
          "type": "object",
          "description": "Summary statistics per arm, keyed by arm label",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "n": { "type": "integer", "minimum": 0 },
